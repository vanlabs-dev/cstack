# Copy this file to infra/docker/.env (or repo-root .env, picked up by
# docker compose) and fill in values. Compose reads this file at up time;
# values flow into the api service environment.

# Required for the API key gate. Any non-empty string works for local dev.
SIGNALGUARD_API_DEV_API_KEY=dev-secret

# Optional: enable the LLM narrative pass during audit runs and the
# /findings/{id}/narrative endpoint. Leaving the key blank disables
# narratives even when CSTACK_LLM_NARRATIVE_ENABLED=true (the provider
# will fail-fast).
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Default off; flip to true to opt narratives in.
# CSTACK_LLM_NARRATIVE_ENABLED=false

# MaxMind GeoLite2 license for the geoipupdate service. Free signup at
# https://www.maxmind.com/ (a few minutes; account + license key). When
# set, the geoipupdate container downloads the GeoLite2-ASN database
# weekly and ASN feature extraction uses real autonomous system
# numbers. When unset, the geoipupdate service exits early and ASN
# lookups fall back to the deterministic prefix table that fixture
# tenants rely on anyway.
# MAXMIND_ACCOUNT_ID=
# MAXMIND_LICENSE_KEY=
