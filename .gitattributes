# Default: detect text files automatically, normalize to LF in the repo.
* text=auto eol=lf

# Windows-native scripts must keep CRLF line endings to remain executable on Windows.
*.ps1 text eol=crlf
*.psm1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binaries: skip text munging entirely.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pfx binary
*.cer binary
*.p12 binary
*.duckdb binary
